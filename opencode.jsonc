{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "autoupdate": true,
  "references": {
    // Repo usage
    "screenpipe": {
      "repository": "https://github.com/screenpipe/screenpipe",
    },
    "shadow": {
      "repository": "https://github.com/ghostwright/shadow",
    },
    // Effect
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
    },
    "opencode-beta": {
      "repository": "https://github.com/anomalyco/opencode",
      "branch": "beta",
    },
    "hazel": {
      "repository": "https://github.com/HazelChat/hazel",
    },
    "maple": {
      "repository": "https://github.com/Makisuo/maple",
    },
    // Patterns
    "plane": {
      "repository": "github.com/makeplane/plane",
    },
    "twenty": {
      "repository": "https://github.com/twentyhq/twenty",
    },
    "mattermost": {
      "repository": "https://github.com/mattermost/mattermost",
    },
  },
  "mcp": {
    "uidotsh": {
      "type": "remote",
      "url": "https://ui.sh/mcp?agent=opencode",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:UIDOTSH_TOKEN}",
      },
    },
  },
}

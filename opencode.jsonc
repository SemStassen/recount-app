{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "autoupdate": true,
  "references": {
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
    },
    "plane": {
      "repository": "github.com/makeplane/plane",
    },
    "screenpipe": {
      "repository": "https://github.com/screenpipe/screenpipe",
    },
    "shadow": {
      "repository": "https://github.com/ghostwright/shadow",
    },
    "ghost-os": {
      "repository": "https://github.com/ghostwright/ghost-os",
    },
    "maple": {
      "repository": "https://github.com/Makisuo/maple",
    },
    "mattermost": {
      "repository": "https://github.com/mattermost/mattermost",
    },
  },
  "mcp": {
    "uidotsh": {
      "type": "remote",
      "url": "https://ui.sh/mcp?agent=opencode",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:UIDOTSH_TOKEN}",
      },
    },
  },
}

{
  "name": "recount",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && turbo build",
    "clean": "turbo clean --parallel && rm -rf .turbo/cache node_modules",
    "dev": "turbo dev --parallel",
    "format": "oxfmt --write .",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "subtree:create:effect": "git remote add effect https://github.com/Effect-TS/effect-smol && git subtree add --prefix=.better-agents/effect effect main --squash",
    "subtree:update:effect": "git subtree pull --prefix=.better-agents/effect effect main --squash",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
  "private": true,
  "workspaces": {
    "packages": [
      "interface",
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@effect/atom-react": "^4.0.0-beta.43",
      "@effect/opentelemetry": "^4.0.0-beta.43",
      "@effect/platform-bun": "^4.0.0-beta.43",
      "@effect/sql-pg": "^4.0.0-beta.43",
      "better-auth": "^1.5.6",
      "drizzle-orm": "1.0.0-beta.18-7eb39f0",
      "effect": "^4.0.0-beta.43",
      "uuid": "^13.0.0"
    },
    "catalogs": {
      "dev": {
        "@rolldown/plugin-babel": "^0.2.2",
        "@tailwindcss/vite": "^4.1.17",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.1",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "drizzle-kit": "1.0.0-beta.18-7eb39f0",
        "typescript": "^6.0.2",
        "vite": "^8.0.1"
      },
      "frontend": {
        "@base-ui/react": "^1.3.0",
        "@tanstack/react-form": "^1.23.0",
        "class-variance-authority": "^0.7.1",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
      }
    }
  },
  "devDependencies": {
    "@effect/language-service": "^0.80.0",
    "@effect/vitest": "^0.27.0",
    "@types/bun": "^1.3.11",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.8.16",
    "typescript": "catalog:dev",
    "ultracite": "7.3.0",
    "vitest": "^4.1.0",
    "@inlang/paraglide-js": "^2.15.1",
    "@inlang/cli": "^3.0.0"
  },
  "dependencies": {}
}

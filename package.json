{
  "name": "recount",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && turbo build",
    "clean": "turbo clean --parallel && rm -rf .turbo/cache node_modules",
    "dev": "bun run dev:web",
    "dev:all": "turbo run dev //#dev:caddy --parallel --filter=@recount/backend --filter=@recount/electric-proxy --filter=@recount/web --filter=@recount/desktop",
    "dev:caddy": "caddy run --config Caddyfile",
    "dev:desktop": "turbo run dev //#dev:caddy --parallel --filter=@recount/backend --filter=@recount/electric-proxy --filter=@recount/desktop",
    "dev:web": "turbo run dev //#dev:caddy --parallel --filter=@recount/backend --filter=@recount/electric-proxy --filter=@recount/web",
    "format": "oxfmt --write .",
    "lint": "turbo lint",
    "lint:ast": "ast-grep scan",
    "lint:ast:test": "ast-grep test",
    "prepare": "lefthook install",
    "typecheck": "turbo typecheck",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
  "private": true,
  "workspaces": {
    "packages": [
      "interface",
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@effect/atom-react": "^4.0.0-beta.78",
      "@effect/opentelemetry": "^4.0.0-beta.78",
      "@effect/platform-bun": "^4.0.0-beta.78",
      "@effect/sql-pg": "^4.0.0-beta.78",
      "better-auth": "^1.6.14",
      "drizzle-orm": "1.0.0-rc.2",
      "effect": "^4.0.0-beta.78",
      "uuid": "^14.0.0"
    },
    "catalogs": {
      "dev": {
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss/vite": "^4.3.0",
        "@types/react": "^19.2.16",
        "@types/react-dom": "^19.2.1",
        "@vitejs/plugin-react": "^6.0.2",
        "babel-plugin-react-compiler": "^1.0.0",
        "drizzle-kit": "1.0.0-rc.2",
        "typescript": "^6.0.3",
        "vite": "^8.0.16"
      },
      "frontend": {
        "@base-ui/react": "^1.5.0",
        "@tanstack/react-form": "^1.33.0",
        "class-variance-authority": "^0.7.1",
        "motion": "^12.39.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
      }
    }
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.43.0",
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "^0.29.0",
    "@inlang/cli": "^3.1.11",
    "@inlang/paraglide-js": "^2.18.1",
    "@types/bun": "^1.3.14",
    "lefthook": "^2.1.8",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.9.14",
    "typescript": "catalog:dev",
    "ultracite": "7.8.2",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "^4.0.0-beta.78",
    "alchemy": "2.0.0-beta.38",
    "effect": "catalog:"
  },
  "trustedDependencies": [
    "@ast-grep/cli"
  ]
}

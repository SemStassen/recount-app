{
  "name": "recount",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && turbo build",
    "clean": "turbo clean --parallel && rm -rf .turbo/cache node_modules",
    "dev": "bun run dev:caddy & bun run dev:apps",
    "dev:apps": "turbo dev --parallel --filter=@recount/backend --filter=@recount/electric-proxy --filter=@recount/web",
    "dev:caddy": "caddy run --config Caddyfile",
    "format": "oxfmt --write .",
    "lint": "turbo lint",
    "lint:ast": "ast-grep scan",
    "lint:ast:test": "ast-grep test",
    "typecheck": "turbo typecheck",
    "subtree:create:effect": "git remote add effect https://github.com/Effect-TS/effect-smol && git subtree add --prefix=.better-agents/effect effect main --squash",
    "subtree:update:effect": "git subtree pull --prefix=.better-agents/effect effect main --squash",
    "ultracite:check": "ultracite check",
    "ultracite:fix": "ultracite fix",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
  "private": true,
  "workspaces": {
    "packages": [
      "interface",
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@effect/atom-react": "^4.0.0-beta.66",
      "@effect/opentelemetry": "^4.0.0-beta.66",
      "@effect/platform-bun": "^4.0.0-beta.66",
      "@effect/sql-pg": "^4.0.0-beta.66",
      "better-auth": "^1.6.10",
      "drizzle-orm": "1.0.0-rc.2",
      "effect": "^4.0.0-beta.66",
      "uuid": "^14.0.0"
    },
    "catalogs": {
      "dev": {
        "@rolldown/plugin-babel": "^0.2.3",
        "@tailwindcss/vite": "^4.3.0",
        "@types/react": "^19.2.2",
        "@types/react-dom": "^19.2.1",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "drizzle-kit": "1.0.0-rc.2",
        "typescript": "^6.0.3",
        "vite": "^8.0.12"
      },
      "frontend": {
        "@base-ui/react": "^1.4.1",
        "@tanstack/react-form": "^1.29.2",
        "class-variance-authority": "^0.7.1",
        "motion": "^12.23.12",
        "react": "^19.2.6",
        "react-dom": "^19.2.6"
      }
    }
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.42.2",
    "@effect/language-service": "^0.86.0",
    "@effect/vitest": "^0.29.0",
    "@inlang/cli": "^3.1.10",
    "@inlang/paraglide-js": "^2.17.0",
    "@types/bun": "^1.3.13",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "turbo": "^2.9.12",
    "typescript": "catalog:dev",
    "ultracite": "7.7.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "^4.0.0-beta.66",
    "alchemy": "2.0.0-beta.36",
    "effect": "catalog:"
  },
  "trustedDependencies": [
    "@ast-grep/cli"
  ]
}

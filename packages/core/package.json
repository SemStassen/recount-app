{
  "name": "@recount/core",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist .turbo tsconfig.tsbuildinfo",
    "format": "oxfmt --write .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sindresorhus/slugify": "^3.0.0",
    "effect": "catalog:",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@recount/config": "workspace:*",
    "typescript": "catalog:dev"
  },
  "imports": {
    "#api/*": "./src/api/*.ts",
    "#internal/*": "./src/internal/*.ts",
    "#modules/*/api": "./src/modules/*/api/index.ts",
    "#modules/*": "./src/modules/*.ts",
    "#shared/*": "./src/shared/*.ts"
  },
  "exports": {
    "./http": "./src/api/http/index.ts",
    "./rpc": "./src/api/rpc/index.ts",
    "./modules/*/api": "./src/modules/*/api/index.ts",
    "./modules/*": "./src/modules/*/index.ts",
    "./modules/*/persistence": "./src/modules/*/persistence/index.ts",
    "./modules/*/ports": "./src/modules/*/ports/index.ts",
    "./shared/*": "./src/shared/*/index.ts",
    "./shared/headers": "./src/shared/headers.ts"
  }
}

{
  "name": "@recount/db",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist .turbo tsconfig.tsbuildinfo",
    "format": "oxfmt --write .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "db:push": "bun --env-file=.env.local run drizzle-kit push"
  },
  "dependencies": {
    "@effect/sql-pg": "catalog:",
    "@recount/core": "workspace:*",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@recount/config": "workspace:*",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "imports": {
    "#utils/*": "./src/utils/*.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}

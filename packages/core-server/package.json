{
  "name": "@recount/core-server",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist .turbo tsconfig.tsbuildinfo",
    "format": "oxfmt --write .",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@recount/core": "workspace:*",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@recount/config": "workspace:*",
    "typescript": "catalog:dev"
  },
  "imports": {
    "#modules/*": "./src/modules/*.ts"
  },
  "exports": {
    "./shared/*": "./src/shared/*/index.ts"
  }
}

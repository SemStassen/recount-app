{
  "name": "@recount/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules dist .turbo tsconfig.tsbuildinfo && cargo clean --manifest-path src-tauri/Cargo.toml",
    "prepare:screenpipe": "bun run scripts/prepare-screenpipe-sidecar.ts",
    "prepare:shadow": "bun run scripts/prepare-shadow-sidecar.ts",
    "prepare:sidecars": "bun run prepare:screenpipe && bun run prepare:shadow",
    "dev": "bun run prepare:sidecars && tauri dev",
    "dev:vite": "vite dev",
    "build": "bun run prepare:sidecars && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@recount/interface": "workspace:*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "~2.4.3",
    "@tauri-apps/plugin-http": "^2.5.3",
    "@tauri-apps/plugin-opener": "~2.5.0",
    "@tauri-apps/plugin-os": "~2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.2",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "effect": "catalog:",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend",
    "screenpipe": "0.4.15"
  },
  "devDependencies": {
    "@recount/config": "workspace:*",
    "@tauri-apps/cli": "^2.8.4",
    "typescript": "catalog:dev",
    "vite": "catalog:dev"
  },
  "optionalDependencies": {
    "@screenpipe/cli-darwin-arm64": "0.4.15",
    "@screenpipe/cli-darwin-x64": "0.4.15",
    "@screenpipe/cli-linux-x64": "0.4.15",
    "@screenpipe/cli-win32-x64": "0.4.15"
  }
}
